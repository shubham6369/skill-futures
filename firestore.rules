rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'shubham67257@gmail.com'
      );
    }

    // Courses and Notices are publicly readable, but only admins can write
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /trainings/{trainingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User profile: users can read/write their own; admins can read/write all
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // Payout requests: users can create and read their own; admins can manage all
    match /payoutRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    // Enrolled courses
    match /userCourses/{id} {
      allow read, write: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Global settings: only admins can read/write
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
